{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "POS.Desktop": "Debug"
    },
    "File": {
      "Directory": "IMAGYN/POS/Desktop/Logs",
      "FileName": "pos-desktop.log"
    }
  },
  "WebView2": {
    "UserDataFolder": "IMAGYN/POS/Desktop/WebView2"
  },
  "Database": {
    "DataFolder": "IMAGYN/POS/Desktop/Data",
    "DatabaseName": "pos_local.db",
    "ApplyMigrationsOnStartup": true
  },
  "Provisioning": {
    "TenantId": null,
    "LocationId": null,
    "TerminalId": null
  },
  "ShiftOpen": {
    "CashDrawerLimit": 25000,
    "AutoSafeDropThreshold": 20000,
    "Checklist": [
      "Physical cash counted & verified",
      "Barcode scanner powered on",
      "Receipt printer has paper loaded",
      "Card terminal connected & tested",
      "Product catalog synced & up to date"
    ]
  },
  "Sync": {
    "ApiBaseUrl": "https://localhost:5001",
    "IngestPath": "/api/sync/ingest",
    "TimeoutSeconds": 15,
    "ClockSkewSeconds": 300,
    "BatchSize": 50,
    "PollIntervalSeconds": 10,
    "InitialBackoffSeconds": 2,
    "MaxBackoffSeconds": 300,
    "BackoffMultiplier": 2.0
  }
}
